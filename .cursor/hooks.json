{
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "type": "command",
        "command": "node .cursor/hooks/block-app-api-write.mjs",
        "failClosed": true,
        "timeout": 5
      }
    ],
    "beforeShellExecution": [
      {
        "type": "command",
        "command": "node .cursor/hooks/block-app-api-shell.mjs",
        "failClosed": true,
        "timeout": 5
      }
    ],
    "postToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "type": "command",
        "command": "node .cursor/hooks/on-write-nudge.mjs",
        "timeout": 5
      }
    ]
  }
}
